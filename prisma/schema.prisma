generator client {
  provider = "prisma-client-js"
}

// Prisma 7: datasource KHÔNG còn nhận `url` trong file schema nữa.
// URL cho Migrate/CLI được cấu hình ở prisma.config.ts; URL cho PrismaClient
// lúc runtime được truyền qua driver adapter (xem src/lib/prisma.ts, scripts/sync-nguonc.ts).
datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  favorites     FavoriteFilm[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FavoriteFilm {
  id        String   @id @default(cuid())
  userId    String
  filmSlug  String
  filmName  String
  thumbUrl  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, filmSlug])
}

// ===== Cache dữ liệu phim đồng bộ từ NguonC (script scripts/sync-nguonc.ts) =====

model Film {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  originalName   String?
  thumbUrl       String?
  posterUrl      String?
  description    String?
  totalEpisodes  Int?
  currentEpisode String?
  time           String?
  quality        String?
  language       String?
  year           Int?
  director       String?
  casts          String?
  sourceModified DateTime?
  syncedAt       DateTime @updatedAt
  createdAt      DateTime @default(now())

  genres    FilmGenre[]
  countries FilmCountry[]

  @@index([year])
}

model Genre {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  films FilmGenre[]
}

model Country {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  films FilmCountry[]
}

model FilmGenre {
  filmId  String
  genreId String
  film    Film  @relation(fields: [filmId], references: [id], onDelete: Cascade)
  genre   Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([filmId, genreId])
}

model FilmCountry {
  filmId    String
  countryId String
  film      Film    @relation(fields: [filmId], references: [id], onDelete: Cascade)
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([filmId, countryId])
}
